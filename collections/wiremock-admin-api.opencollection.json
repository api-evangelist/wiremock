        {
          "info": {
            "name": "Delete Stub Mappings Matching Metadata",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "http://localhost:8080/__admin/mappings/remove-by-metadata",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Delete Stub Mappings Matching Metadata"
        }
