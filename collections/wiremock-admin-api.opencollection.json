        {
          "info": {
            "name": "Find Unmatched Requests",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "http://localhost:8080/__admin/requests/unmatched"
          },
          "docs": "Get details of logged requests that weren't matched by any stub mapping"
        }
